# ~/.bashrc — sourced from ~/.bash_profile so it also loads in macOS login shells.
# Adapted for macOS with Bash installed via Homebrew (chsh -s /opt/homebrew/bin/bash).

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# --- Homebrew (Apple Silicon): set up FIRST so pyenv's shims can sit in front of it ---
eval "$(/opt/homebrew/bin/brew shellenv)"

# Local runtime libraries (HSL, etc.).
# Use DYLD_FALLBACK_LIBRARY_PATH, not DYLD_LIBRARY_PATH: the latter is *forced* (it overrides each
# binary's correctly-linked libraries) and is stripped by SIP whenever the load chain crosses a
# system-protected binary. FALLBACK is consulted only when the normal lookup fails — which is
# exactly what you want for adding HSL without shadowing anything else.
export DYLD_FALLBACK_LIBRARY_PATH="$HOME/.local/lib:$HOME/.local/lib/libhsl:/opt/homebrew/lib${DYLD_FALLBACK_LIBRARY_PATH:+:$DYLD_FALLBACK_LIBRARY_PATH}"

# login to the debian VM
alias debian_vm='ssh -F /Users/feodor/.lima/debian/ssh.config lima-debian'

# pip install --user console scripts (for a pyenv CPython these land in ~/.local/bin)
export PATH="$HOME/.local/bin:$PATH"

# --- pyenv: set up LAST so its shims take precedence over Homebrew's python ---
export PYENV_ROOT="$HOME/.pyenv"
[[ -d "$PYENV_ROOT/bin" ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init - bash)"
eval "$(pyenv virtualenv-init -)"

# Don't put duplicate lines or lines starting with space in the history.
HISTCONTROL=ignoreboth

# Append to the history file, don't overwrite it
shopt -s histappend

# For setting history length
HISTSIZE=100000
HISTFILESIZE=200000

# Check the window size after each command
shopt -s checkwinsize

# If set, the pattern "**" used in a pathname expansion context will match all files and directories
# shopt -s globstar

# Make less more friendly for non-text input files
export LESSOPEN="|/opt/homebrew/bin/lesspipe.sh %s"

# Set variable identifying the chroot (less relevant on macOS, but retained)
if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]; then
    debian_chroot=$(cat /etc/debian_chroot)
fi

# Set a fancy prompt (non-color, unless we know we want color)
case "$TERM" in
    xterm-color|*-256color) color_prompt=yes;;
esac

# Color codes (tput works on macOS Terminal/iTerm)
red=$(tput setaf 1)
green=$(tput setaf 2)
yellow=$(tput setaf 3)
yellow2=$(tput setaf 190)
blue=$(tput setaf 4)
blue2=$(tput setaf 12)
magenta=$(tput setaf 5)
cyan=$(tput setaf 6)
silver=$(tput setaf 7)
grey=$(tput setaf 8)
pink=$(tput setaf 9)
default=$(tput sgr0)

# User config
if [ $UID == 0 ]; then
  ucolor=$red
else
  ucolor=$yellow
fi

# Uncomment for a colored prompt if desired
# force_color_prompt=yes

if [ -n "$force_color_prompt" ]; then
    if [ -x /usr/bin/tput ] && tput setaf 1 >&/dev/null; then
	color_prompt=yes
    else
	color_prompt=
    fi
fi

get_current_dir() {
  dcolor=${1-'default'}
  pcolor=${2-'default'}
  pwd|awk -F/ -v n="$(tput cols)" -v h="^$HOME" -v u="$(echo $USER@$HOSTNAME|cut -d . -f 1)" -v r="${!pcolor}" -v d="${!dcolor}" \
    '{sub(h,"~"); n=n-length(u)-8;} length($0)<=n || NF==2 {print d$0; exit;} \
    NF>2 {b=d$1"/"$2"/"r".."d"/"; e=$NF; n=n-length(b e)+length(d r d); for (i=NF-1; i>2; i--) \
    {n-=length($i)+1; if (n < 0) break; e=$i"/"e}} {print b e;}'
}
if [ "$color_prompt" = yes ]; then
  PS1="\[${blue2}\]╭─(\[${ucolor}\]\u\[${blue2}\]@\[${silver}\]\h\[${blue2}\])-[\$(get_current_dir 'green' 'red')\[${blue2}\]]\n\[${blue2}\]╰─(\[${yellow2}\]\$(date +%H:%M)\[${blue2}\])>\[${default}\] "
else
  PS1="╭─(\u@\h)-[\$(get_current_dir)]\n╰─(\$(date +%H:%M))> "
fi
unset color_prompt force_color_prompt

# If this is an xterm set the title (works in macOS Terminal/iTerm)
case "$TERM" in
xterm*|rxvt*)
    PS1="\[\e]0;${debian_chroot:+($debian_chroot)}\u@\h: \w\a\]$PS1"
    ;;
*)
    ;;
esac

# Enable color support for ls (GNU coreutils via Homebrew, g-prefixed)
if [ -x /opt/homebrew/bin/gdircolors ]; then
    test -r ~/.dircolors && eval "$(gdircolors -b ~/.dircolors)" || eval "$(gdircolors -b)"
    alias ls='gls --color=auto'
    alias dir='gdir --color=auto'
    alias vdir='gvdir --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

# Colored GCC warnings and errors (if using GCC from Homebrew)
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# Some ls aliases (these use GNU ls flags, so they rely on the gls alias above / coreutils)
alias ll='ls -alvFh --group-directories-first'
alias la='ls -A'
alias l='ls -CF'

# Alias definitions (load from separate file if exists)
if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

# Programmable completion (bash-completion@2 for Homebrew's bash 5 installs its loader here)
if ! shopt -oq posix; then
  if [[ -r /opt/homebrew/etc/profile.d/bash_completion.sh ]]; then
    . /opt/homebrew/etc/profile.d/bash_completion.sh
  fi
fi

# Source fzf if installed (brew install fzf)
[ -f ~/.fzf.bash ] && source ~/.fzf.bash
